# ── App ──────────────────────────────────────────────────────────
APP_NAME="LangGraph AgentOS"
APP_VERSION="0.1.0"
DEBUG=false
API_PREFIX="/api/v1"

# ── Database ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=agentosuser
POSTGRES_PASSWORD=agentospassword
POSTGRES_DB=agentosdb

# ── LLM ──────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSyDHB8FJYaonN_d-6ALL-moO1YZOJOQqpns
# Example Gemini model:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-1.5-flash

# ── Security (Phase 3) ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ───────────────────────────────────────────────────────
ARTIFACTS_DIR=./storage/artifacts

# ── Testing / deterministic mode ───────────────────────────────────
USE_MOCK_AGENTS=false
